    "Equations": [
        "equations{ '$MIMO$ ui_mspt_system_design__mspt_cmod' } = define()\r",
        "{\r",
        "\tobj = ssc_create();\r",
        "\r",
        "\t//#ssc_auto_exec(obj, 'geothermal', 2);\r",
        "\t\r",
        "\t//\tret_d = ssc_dump(obj, 'physical_trough_v2_mimo_ssc_auto_exec.lk');\r",
        "\tret = ssc_exec(obj, 'geothermal');\r",
        "\t\r",
        "\tif(ret == 0)\r",
        "\t{\r",
        "\t\t${is_success_auto_exec} = 1;\r",
        "\t\t\r",
        "\t\t${design_temp_calc} = ssc_var(obj, \"design_temp\");\r",
        "\t\t\r",
        "\t\t${plant_brine_eff_calc} = ssc_var( obj, 'plant_brine_eff');\r",
        "\t\t${gross_output_calc} = ssc_var(obj, \"gross_output\");\r",
        "\t\t\r",
        "\t\t${num_wells_calc} = ssc_var(obj, \"num_wells_getem_output\");\r",
        "\t\t${num_wells_getem_inj_calc} = ssc_var(obj, \"num_wells_getem_inj\");\r",
        "\t\t${num_wells_getem_prod_drilled_calc} = ssc_var(obj, \"num_wells_getem_prod_drilled\");\r",
        "\t\t${num_wells_getem_inj_drilled_calc} = ssc_var(obj, \"num_wells_getem_inj_drilled\");\r",
        "\t\t\r",
        "\t\t${pump_watthr_per_lb_calc} = ssc_var(obj, \"pump_watthr_per_lb\");\r",
        "\t\t${pumpwork_prod_calc} = ssc_var(obj, \"pumpwork_prod\");\r",
        "\t\t${pump_size_hp_calc} = ssc_var(obj, \"pump_size_hp\");\r",
        "\t\t${pumpwork_inj_calc} = ssc_var(obj, \"pumpwork_inj\");\r",
        "\t\t${pump_depth_ft_calc} = ssc_var(obj, \"pump_depth_ft\");\r",
        "\t\t${inj_pump_hp_calc} = ssc_var(obj, \"inj_pump_hp\");\r",
        "\t\t${pump_work_calc} = ssc_var(obj, \"pump_work\");\r",
        "\t\t\r",
        "\t\t${reservoir_pressure_calc} = ssc_var(obj, \"reservoir_pressure\");\r",
        "\t\t${reservoir_avg_temp_calc} = ssc_var(obj, \"reservoir_avg_temp\");\r",
        "\t\t${bottom_hole_pressure_calc} = ssc_var(obj, \"bottom_hole_pressure\");\r",
        "\t\t\r",
        "\t\t${net_plant_output_calc} = ssc_var(obj, \"net_plant_output\");\r",
        "\t\t${system_capacity_calc} = ssc_var(obj, \"system_capacity\");\r",
        "\t\t\r",
        "\t\t${pump_only_cost_calc} = ssc_var(obj, \"pump_only_cost\");\r",
        "\t\t${pump_cost_install_calc} = ssc_var(obj, \"pump_cost_install\");\r",
        "\t\t\r",
        "\t\t${baseline_cost_calc} = ssc_var(obj, 'baseline_cost');\r",
        "\r",
        "\t\t\r",
        "\t\t// System Design\r",
        "\t\t//${csp.dtr.pwrb.nameplate} = ssc_var(obj, \"nameplate\");\r",
        "\t\t//${q_pb_design} = ssc_var(obj, \"q_dot_cycle_des\");\r",
        "\t}\r",
        "\telse{\r",
        "\t\t${is_success_auto_exec} = -1;\r",
