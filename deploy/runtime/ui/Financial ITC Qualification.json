    "Equations": [
        "/*\r",
        "equations{ 'ui_system_capacity' } = define() {\r",
        "  return ${system_capacity}; \r",
        "};\r",
        "*/\r",
        "\r",
        "equations{'batt_itc_basis_cost'} = define() {\r",
        "\ttech = technology();\r",
        "\tif (strpos(tech, 'Battery') != -1) {\r",
        "\t\treturn ${battery_total_cost_lcos};\r",
        "\t}\r",
        "\telse {\r",
        "\t\treturn 0;\r",
        "\t}\r",
        "};\r",
        "\r",
        "equations{'batt_itc_basis_percent'} = define() {\r",
        "\treturn ${batt_itc_basis_cost} / ${total_installed_cost} * 100; //%\r",
        "};\r",
        "\r",
        "equations{'system_itc_basis_cost'} = define() {\r",
        "\ttech = technology();\r",
        "\tif (strpos(tech, 'Battery') != -1) {\r",
        "\t\treturn ${total_system_installed_cost};\r",
        "\t}\r",
        "\telse {\r",
        "\t\treturn ${total_installed_cost};\r",
        "\t}\r",
        "};\r",
        "\r",
        "equations{'system_itc_basis_percent'} = define() {\r",
        "\treturn ${system_itc_basis_cost} / ${total_installed_cost} * 100; //%\r",
        "};\r",
        "\r",
        "equations{'itc_basis_cost'} = define() {\r",
        "\treturn ${itc_basis_percent_input} / 100.0 * ${total_installed_cost};\r",
        "};\r",
        "\t"
    ],
    "Callbacks": [
        "on_load{'Financial ITC Qualification'} = define() {\r",
        "\tset_itc_basis_choice();\r",
        "\tshow_battery_itc();\r",
        "};\r",
        "\r",
        "on_change{'itc_qualification_choice'} = define() {\r",
        "\tset_itc_basis_choice();\r",
        "};\r",
        "\r",
        "function show_battery_itc() {\r",
        "\ttech = technology();\r",
        "\tis_batt = strpos(tech, 'Battery');\r",
        "\tshow('batt_itc_basis_cost', is_batt);\r",
        "\tshow('batt_itc_basis_percent', is_batt);\r",
        "\tshow('batt_itc_percent_lbl', is_batt);\r",
        "\trefresh();\r",
        "}\r",
        "\r",
        "function set_itc_basis_choice() {\r",
        "\tchoice = value('itc_qualification_choice');\r",
        "\t\r",
        "\t//Installed Costs Driven Controls\r",
        "\tenable('depr_itc_fed_capex', !choice);\r",
        "\tenable('depr_itc_sta_capex', !choice);\r",
        "\tenable('itc_basis_depreciation_allocation', !choice);\r",
        "\tenable('non_itc_basis_depreciation_allocation', !choice);\r",
        "\tenable('itc_basis_depreciation_set', !choice);\r",
        "\tenable('itc_basis_percent_input', !choice);\r",
        "\t\r",
        "\t//Depreciation Driven Controls\r",
        "\tenable('depr_itc_fed_macrs_5', choice);\r",
        "\tenable('depr_itc_sta_macrs_5', choice);\r",
        "\tenable('depr_itc_fed_macrs_15', choice);\r",
        "\tenable('depr_itc_sta_macrs_15', choice);\r",
        "\tenable('depr_itc_fed_sl_5', choice);\r",
        "\tenable('depr_itc_sta_sl_5', choice);\r",
        "\tenable('depr_itc_fed_sl_15', choice);\r",
        "\tenable('depr_itc_sta_sl_15', choice);\r",
        "\tenable('depr_itc_fed_sl_20', choice);\r",
        "\tenable('depr_itc_sta_sl_20', choice);\r",
        "\tenable('depr_itc_fed_sl_39', choice);\r",
        "\tenable('depr_itc_sta_sl_39', choice);\r",
        "\tenable('depr_itc_fed_custom', choice);\r",
        "\tenable('depr_itc_sta_custom', choice);\r",
        "\tshow('itc_qual_warning', choice);\r",
        "\t\r",
        "\trefresh();\r",
        "\t\r",
        "\t\r",
        "\t\r",
        "}"
    ]
