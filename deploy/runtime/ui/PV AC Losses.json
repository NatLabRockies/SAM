    "Callbacks": [
        "function clipping_correction_method_choice() {\r",
        "\tif (value('enable_subhourly_clipping_ui') == 1) {\r",
        "\t\tif (value('clipping_correction_method_ui') == 1) {\r",
        "\t\t\tvalue('enable_subhourly_clipping', 0);\r",
        "\t\t\tvalue('enable_subinterval_distribution', 1);\r",
        "\t\t}\r",
        "\t\telse {\r",
        "\t\t\tvalue('enable_subhourly_clipping', 1);\r",
        "\t\t\tvalue('enable_subinterval_distribution', 0);\r",
        "\t\t}\r",
        "\t}\r",
        "\telse {\r",
        "\t\tvalue('enable_subhourly_clipping', 0);\r",
        "\t\tvalue('enable_subinterval_distribution', 0);\r",
        "\t}\r",
        "}\r",
        "\r",
        "on_load{'PV AC Losses'} = define() {\r",
        "\ttimestep = value('ui_step_minutes'); // from Solar Resource Information form\r",
        "\tenable('enable_subhourly_clipping_ui', timestep == 60);\r",
