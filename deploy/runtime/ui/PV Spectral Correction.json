    "Equations": [
        "equations{'spectral_correction_celltech'} = define() {\r",
        "\tmodel = ${module_model};\r",
        "\tif (model == 0) {\r",
        "\t\treturn 'Cell technology is not specified for the Simple Efficiency model, as spectral correction is not applied.';\r",
        "\t}\r",
        "\telse {\r",
        "\t\treturn ?${celltech} [\r",
        "\t\t\t'monoSi',\r",
        "\t\t\t'multiSi',\r",
        "\t\t\t'CdTe',\r",
        "\t\t\t'CIS',\r",
        "\t\t\t'CIGS',\r",
        "\t\t\t'Amorphous',\r",
        "\t\t\t'Cell type could not be determined'\r",
        "\t\t];\r",
        "\t}\r",
        "};\r",
        "\r",
        "equations{'celltech'} = define() {\r",
        "\tmodel = ${module_model};\r",
        "\tif (model == 0) {\r",
        "\t\treturn 6; //default to mono? spe does not use scf\r",
        "\t}\r",
        "\telse if (model == 1) {\r",
        "\t\tm = lower(${cec_material});\r",
        "\t\tif( strpos(m,'mono')>=0 ) celltech = 0;\r",
        "\t\telseif ( strpos(m, 'multi') >= 0 ) celltech = 1;\r",
        "\t\telseif( strpos(m, 'thin')>=0 ) celltech=2;\r",
        "\t\telseif( strpos(m, 'cis')>=0) celltech=3;\r",
        "\t\telseif( strpos(m, 'cigs')>=0) celltech=4;\r",
        "\t\telseif( strpos(m, 'a-si')>=0) celltech=5;\r",
        "\t\telse return 6;\r",
        "\t\treturn celltech;\r",
        "\t}\r",
        "\telse if (model == 2) {\r",
        "\t\treturn ${6par_celltech};\r",
        "\t}\r",
        "\telse if (model == 3) {\r",
        "\t\tm = lower(${snl_material});\r",
        "\t\tif( strpos(m,'c-si')>=0 ) celltech = 0;\r",
        "\t\telseif ( strpos(m, 'mc') >= 0 ) celltech = 1;\r",
        "\t\telseif( strpos(m, 'cdte')>=0 ) celltech=2;\r",
        "\t\telseif( strpos(m, 'cis')>=0) celltech=3;\r",
        "\t\telseif( strpos(m, 'cigs')>=0) celltech=4;\r",
        "\t\telseif( strpos(m, 'a-si')>=0) celltech=5;\r",
        "\t\telse celltech=6;\r",
        "\t\treturn celltech;\r",
        "\t}\r",
        "\telse if (model == 4) {\r",
        "\t\treturn ${sd11par_type};\r",
        "\t}\r",
        "\telse return 6;\r",
        "};\r",
        "\r",
        "equations{'$MIMO spectral recommend'} = define() {\r",
        "\t//choice = ${spectral_recommend_choice};\r",
        "\tmodel = ${module_model};\r",
        "\tis_cec = model == 1 || model == 2;\r",
        "\tmsg = '';\r",
        "\tif (is_cec) {\r",
        "\t\t\r",
        "\t\t//enable('spectral_correction_model_choice', false);\r",
        "\t\tif (${celltech} < 2) {\r",
        "\t\t\tmsg += 'Any model will work for monocrystalline or multicrystalline Silicon cell types.\\n';\r",
        "\t\t\t//if (choice) ${spectral_correction_model_choice} = 0;\r",
        "\t\t}\r",
        "\t\telse {\r",
        "\t\t\tmsg += 'Precipitable water or clearsky index is needed to more accurately calculate spectral correction factors for this cell type. Precipitable water must be available in the weather file for the simulation to complete.\\n';\r",
        "\t\t}\r",
        "\t\tif (isnan(${annual_precipitation})) {\r",
        "\t\t\tmsg += 'Annual precipitable water was not calculated from the weather file. Ensure that precipitable water is included in the weather before using the Airmass and precipitable water option.\\n';\r",
        "\t\t\tif(isnan(${annual_csky_global})) {\r",
        "\t\t\t\tmsg += 'Could not find clearsky ghi from weather data. Clearsky irradiance can still be calculated from weather data. \\n';\r",
        "\t\t\t\t//if (choice) ${spectral_correction_model_choice} = 1;\r",
        "\t\t\t}\r",
        "\t\t\t//else {\r",
        "\t\t\t\t//if (choice) ${spectral_correction_model_choice} =  2;\r",
        "\t\t\t//}\r",
        "\t\t\t\t\r",
        "\t\t}\r",
        "\t\t/*\r",
        "\t\telse {\r",
        "\t\t\t${spectral_correction_model_choice} = 1;\r",
        "\t\t}*/\r",
        "\t\tif (msg == '') { msg = 'No spectral correction messages.'; }\r",
        "\t\t${spectral_correction_msg} = msg;\r",
        "\t\t//property('spectral_correction_msg', 'Text', msg);\r",
        "\t\t\r",
        "\t\t\r",
        "\t\r",
        "\t}\r",
        "};\r",
        "\r",
        "\t\t\t"
    ],
    "Callbacks": [
        "on_load{'PV Spectral Correction'} = define() \r",
        "{\r",
        "\trecommend_model();\r",
        "};\r",
        "\r",
        "on_change{'spectral_recommend_choice'} = define() {\r",
        "\trecommend_model();\r",
        "};\r",
        "\r",
        "function recommend_model() {\r",
        "\tchoice = value('spectral_recommend_choice');\r",
        "\tmodel = value('module_model');\r",
        "\tis_cec = model == 1 || model == 2;\r",
        "\tmsg = '';\r",
        "\tif (is_cec) {\r",
        "\t\tif (choice == 0) { //Not checked\r",
        "\t\t\tenable('spectral_correction_model_choice', true); //keep it enabled\r",
        "\t\t\t\r",
        "\t\t}\r",
        "\t\telse {\r",
        "\t\t\tenable('spectral_correction_model_choice', false);\r",
        "\t\t\tif (value('celltech') < 2) {\r",
        "\t\t\t\tmsg += 'Any model will work for monocrystalline or multicrystalline Silicon cell types.\\n';\r",
        "\t\t\t}\r",
        "\t\t\telse {\r",
        "\t\t\t\tmsg += 'Precipitable water or clearsky index is needed to more accurately calculate spectral correction factors for this cell type. Precipitable water must be available in the weather file for the simulation to complete.\\n';\r",
        "\t\t\t}\r",
        "\t\t\tif (isnan(value('annual_precipitation'))) {\r",
        "\t\t\t\tmsg += 'Annual precipitable water was not calculated from the weather file. Ensure that precipitable water is included in the weather before using the Airmass and precipitable water option.\\n';\r",
        "\t\t\t\tif(isnan(value('annual_csky_global'))) {\r",
        "\t\t\t\t\tmsg += 'Could not find clearsky ghi from weather data.\\n';\r",
        "\t\t\t\t\t//value('spectral_correction_model_choice', 0);\r",
        "\t\t\t\t}\r",
        "\t\t\t\t//else {\r",
        "\t\t\t\t\t//value('spectral_correction_model_choice', 2);\r",
        "\t\t\t\t//}\r",
        "\t\t\t\t\t\r",
        "\t\t\t}\r",
        "\t\t\t//else {\r",
        "\t\t\t//\tvalue('spectral_correction_model_choice', 1);//\r",
        "\t\t\t//}\r",
        "\t\t\tif (msg == '') { msg = 'No spectral correction messages.'; }\r",
        "\t\t\t//value('spectral_correction_msg', msg);\r",
        "\t\t\t//property('spectral_correction_msg', 'Text', msg);\r",
        "\t\t\t\r",
        "\t\t\t\r",
        "\t\t}\r",
        "\t}\r",
        "\trefresh();\r",
        "}\r",
        "/*\r",
        "function check_cec() {\r",
        "\tmodel = value('module_model');\r",
        "\tis_cec = model == 1 || model == 2;\r",
        "\tif (!is_cec) {\r",
        "\t\tenable('spectral_correction_model_choice', false);\r",
        "\t\tenable('spectral_recommend_choice', false);\r",
        "\t\t//property('spectral_correction_msg', 'Text', 'These model options are currently only implemented for the CEC database and CEC user-entered specifications module models.');\r",
        "\t}\r",
        "\telse {\r",
        "\t\tenable('spectral_correction_model_choice', true);\r",
        "\t\tenable('spectral_recommend_choice', true);\r",
        "\t}\r",
        "}*/"
    ]
}