    "Equations": [
        "equations{'spectral_correction_celltech'} = define() {\r",
        "\tmodel = ${module_model};\r",
        "\tif (model == 0) {\r",
        "\t\treturn 'Cell technology is not specified for the Simple Efficiency model, as spectral correction is not applied.';\r",
        "\t}\r",
        "\telse {\r",
        "\t\treturn ?${celltech} [\r",
        "\t\t\t'monoSi',\r",
        "\t\t\t'multiSi',\r",
        "\t\t\t'CdTe',\r",
        "\t\t\t'CIS',\r",
        "\t\t\t'CIGS',\r",
        "\t\t\t'Amorphous',\r",
        "\t\t\t'Cell type could not be determined'\r",
        "\t\t];\r",
        "\t}\r",
        "};\r",
        "\r",
        "equations{'celltech'} = define() {\r",
        "\tmodel = ${module_model};\r",
        "\tif (model == 0) {\r",
        "\t\treturn 6; //default to mono? spe does not use scf\r",
        "\t}\r",
        "\telse if (model == 1) {\r",
        "\t\tm = lower(${cec_material});\r",
        "\t\tif( strpos(m,'mono')>=0 ) celltech = 0;\r",
        "\t\telseif ( strpos(m, 'multi') >= 0 ) celltech = 1;\r",
        "\t\telseif( strpos(m, 'thin')>=0 ) celltech=2;\r",
        "\t\telseif( strpos(m, 'cis')>=0) celltech=3;\r",
        "\t\telseif( strpos(m, 'cigs')>=0) celltech=4;\r",
        "\t\telseif( strpos(m, 'a-si')>=0) celltech=5;\r",
        "\t\telse return 6;\r",
        "\t\treturn celltech;\r",
        "\t}\r",
        "\telse if (model == 2) {\r",
        "\t\treturn ${6par_celltech};\r",
        "\t}\r",
        "\telse if (model == 3) {\r",
        "\t\tm = lower(${snl_material});\r",
        "\t\tif( strpos(m,'c-si')>=0 ) celltech = 0;\r",
        "\t\telseif ( strpos(m, 'mc') >= 0 ) celltech = 1;\r",
        "\t\telseif( strpos(m, 'cdte')>=0 ) celltech=2;\r",
        "\t\telseif( strpos(m, 'cis')>=0) celltech=3;\r",
        "\t\telseif( strpos(m, 'cigs')>=0) celltech=4;\r",
        "\t\telseif( strpos(m, 'a-si')>=0) celltech=5;\r",
        "\t\telse celltech=6;\r",
        "\t\treturn celltech;\r",
        "\t}\r",
        "\telse if (model == 4) {\r",
        "\t\treturn ${sd11par_type};\r",
        "\t}\r",
        "\telse return 6;\r",
        "};\r",
        "\r",
        "equations{'$MIMO spectral recommend'} = define() {\r",
        "\tmodel = ${module_model};\r",
        "\tis_cec = model == 1 || model == 2;\r",
        "\tspec_model = ${spectral_correction_model_choice};\r",
        "\tmsg = '';\r",
        "\tif (spec_model == 0) {\r",
        "\t\tif (${celltech} > 1) {\r",
        "\t\t\tmsg += 'The Air Mass Only option may not be the best option for this cell type. Consider using the Air Mass and Precipitable Water option.\\n\\n';\r",
        "\t\t}\r",
        "\t}\r",
        "\tif (spec_model == 1) {\r",
        "\t\tif (isnan(${annual_precipitation})) {\r",
        "\t\t\tmsg += 'The precipitable water option requires a weather file with total precipitable water data. To use this option, choose a weather file on the Location and Resource page that includes precipitable water data.\\n\\n';\r",
        "\t\t}\r",
        "\t}\t\r",
        "\tif (spec_model == 2) {\r",
        "\t\tif(isnan(${annual_csky_global})) {\r",
        "\t\t\tmsg += 'The weather file on the Location and Resource page does not include clearsky irradiance data. The spectral correction model will calculate clearsky data instead of using data from the weather file.\\n\\n';\r",
        "\t\t}\r",
        "\t}\r",
        "\tif (${celltech} > 5) { // can't identify cell type\r",
        "\t\tmsg += 'The cell type could not be identified for the current module. Spectral correction will be based on coefficients for mono-crystalline modules.\\n\\n';\r",
        "\t}\r",
        "\tif (msg == '') {\r",
        "\t\tmsg = 'No spectral correction messages.';\r",
        "\t}\r",
        "\t${spectral_correction_msg} = msg;\r",
        "};\r",
        "\r",
        "\t\t\t"
    ],
