    "Equations": [
        "equations{'itc_basis_percent_depr'} = define() {\r",
        "\tchoice = ${depr_allocation_choice};\r",
        "\tif (choice == 0) return ${itc_basis_cost_percent_fed};\r",
        "\telse if (choice == 1) return ${itc_basis_cost_percent_sta};\r",
        "\telse return 0;\r",
        "};\r",
        "\r",
        "equations{'non_itc_basis_percent_depr'} = define() {\r",
        "\treturn 100 - ${itc_basis_percent_depr};\r",
        "};"
    ],
    "Callbacks": [
        "on_load{'Financial ITC Depreciation Allocation'} = define() {\r",
        "\tset_itc_basis_choice();\r",
        "\titc_basis_depreciation_choice();\r",
        "};\r",
        "\r",
        "on_change{'itc_basis_depreciation_allocation'} = define() {\r",
        "\titc_basis_depreciation_choice();\r",
        "};\r",
        "\r",
        "on_change{'non_itc_basis_depreciation_allocation'} = define() {\r",
        "\titc_basis_depreciation_choice();\r",
        "};\r",
        "\t\r",
        "\r",
        "on_change{'depr_allocation_choice'} = define() {\r",
        "\t\t\r",
        "\titc_basis_depreciation_choice();\r",
        "\t\t//Depreciation Driven Controls\r",
        "\t\t/*\r",
        "\t\tenable('depr_itc_fed_macrs_5', choice);\r",
        "\t\tenable('depr_itc_sta_macrs_5', choice);\r",
        "\t\tenable('depr_itc_fed_macrs_15', choice);\r",
        "\t\tenable('depr_itc_sta_macrs_15', choice);\r",
        "\t\tenable('depr_itc_fed_sl_5', choice);\r",
        "\t\tenable('depr_itc_sta_sl_5', choice);\r",
        "\t\tenable('depr_itc_fed_sl_15', choice);\r",
        "\t\tenable('depr_itc_sta_sl_15', choice);\r",
        "\t\tenable('depr_itc_fed_sl_20', choice);\r",
        "\t\tenable('depr_itc_sta_sl_20', choice);\r",
        "\t\tenable('depr_itc_fed_sl_39', choice);\r",
        "\t\tenable('depr_itc_sta_sl_39', choice);\r",
        "\t\tenable('depr_itc_fed_custom', choice);\r",
        "\t\tenable('depr_itc_sta_custom', choice);\r",
        "\t\t//show('itc_qual_warning', choice);\r",
        "\t\t*/\r",
        "};\r",
        "\r",
        "\r",
        "function itc_basis_depreciation_choice() {\r",
        "\t\r",
        "\t                        \r",
        "\t//calculate inputs\r",
        "\t/*\r",
        "\tcelltype= ?${6par_celltech}[\r",
        "\t\t'monoSi', 'multiSi/polySi', 'cdte', 'cis', 'cigs', 'amorphous'];\r",
        "\t*/\r",
        "\tchoice = value('depr_allocation_choice');\r",
        "\tpercent = 0;\r",
        "\tif (choice == 0) {\r",
        "\t\tpercent = value('itc_basis_cost_percent_fed');\r",
        "\t}\r",
        "\telse if (choice == 1) {\r",
        "\t\tpercent = value('itc_basis_cost_percent_sta');\r",
        "\t}\r",
        "\telse {\r",
        "\t\tpercent = -1;\r",
        "\t}\r",
        "\t\t\r",
        "\t\t\r",
        "\tdepr_list = ['depr_alloc_macrs_5_percent','depr_alloc_macrs_15_percent',\r",
        "\t\t'depr_alloc_sl_5_percent', 'depr_alloc_sl_15_percent',\r",
        "\t\t'depr_alloc_sl_20_percent', 'depr_alloc_sl_39_percent',\r",
        "\t\t'depr_alloc_custom_percent'];\r",
        "\titc_depr_choice = ?${itc_basis_depreciation_allocation}[\r",
        "\t\t'depr_alloc_macrs_5_percent','depr_alloc_macrs_15_percent',\r",
        "\t\t'depr_alloc_sl_5_percent', 'depr_alloc_sl_15_percent',\r",
        "\t\t'depr_alloc_sl_20_percent', 'depr_alloc_sl_39_percent',\r",
        "\t\t'depr_alloc_custom_percent', 'none'];\r",
        "\tnon_itc_depr_choice = ?${non_itc_basis_depreciation_allocation}[\r",
        "\t\t'depr_alloc_macrs_5_percent','depr_alloc_macrs_15_percent',\r",
        "\t\t'depr_alloc_sl_5_percent', 'depr_alloc_sl_15_percent',\r",
        "\t\t'depr_alloc_sl_20_percent', 'depr_alloc_sl_39_percent',\r",
        "\t\t'depr_alloc_custom_percent', 'none'];\r",
        "\t\r",
        "\tif (choice != 2) {\r",
        "\t\tfor (i = 0; i < #depr_list; i++) {\r",
        "\t\t\tvalue(depr_list[i], 0.0); //Set to 0 to avoid non-depreciable equation warning\r",
        "\t\t}\r",
        "\t\tif (itc_depr_choice == non_itc_depr_choice && itc_depr_choice != 'none') {\r",
        "\t\t\tvalue(itc_depr_choice, 100);\r",
        "\t\t}\r",
        "\t\telse {\r",
        "\t\t\tif (itc_depr_choice != 'none') {\r",
        "\t\t\t\tvalue(itc_depr_choice, percent);\r",
        "\t\t\t}\r",
        "\t\t\tif (non_itc_depr_choice != 'none') {\r",
        "\t\t\t\tvalue(non_itc_depr_choice, 100 - percent);\r",
        "\t\t\t}\r",
        "\t\t}\r",
        "\t\tenable('itc_basis_depreciation_allocation', true);\r",
        "\t\tenable('non_itc_basis_depreciation_allocation', true);\r",
        "\t}\r",
        "\telse {\r",
        "\t\tenable('itc_basis_depreciation_allocation', false);\r",
        "\t\tenable('non_itc_basis_depreciation_allocation', false);\r",
        "\t}\r",
        "\t\r",
        "}"
    ]
}