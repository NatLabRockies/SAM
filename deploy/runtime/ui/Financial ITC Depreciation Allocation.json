    "Callbacks": [
        "on_load{'Financial ITC Depreciation Allocation'} = define() {\r",
        "\tfin = financing();\r",
        "};\r",
        "\r",
        "on_change{'itc_basis_depreciation_set'} = define() {\r",
        "\titc_basis_depreciation_choice();\r",
        "};\r",
        "\r",
        "function itc_basis_depreciation_choice() {\r",
        "\titc_choice = value('itc_basis_depreciation_allocation');\r",
        "\tnon_itc_choice = value('non_itc_basis_depreciation_allocation');\r",
        "\t//calculate inputs\r",
        "\t/*\r",
        "\tcelltype= ?${6par_celltech}[\r",
        "\t\t'monoSi', 'multiSi/polySi', 'cdte', 'cis', 'cigs', 'amorphous'];\r",
        "\t*/\r",
        "\titc_depr_choice = ?${itc_choice}[\r",
        "\t\t'depr_alloc_macrs_5_percent','depr_alloc_macrs_15_percent',\r",
        "\t\t'depr_alloc_sl_5_percent', 'depr_alloc_sl_15_percent',\r",
        "\t\t'depr_alloc_sl_20_percent', 'depr_alloc_sl_39_percent',\r",
        "\t\t'depr_alloc_custom_percent', 'none'];\r",
        "\tnon_itc_depr_choice = ?${non_itc_choice}[\r",
        "\t\t'depr_alloc_macrs_5_percent','depr_alloc_macrs_15_percent',\r",
        "\t\t'depr_alloc_sl_5_percent', 'depr_alloc_sl_15_percent',\r",
        "\t\t'depr_alloc_sl_20_percent', 'depr_alloc_sl_39_percent',\r",
        "\t\t'depr_alloc_custom_percent', 'none'];\r",
        "\tif (itc_choice == non_itc_choice) {\r",
        "\t\tvalue(itc_depr_choice, 100);\r",
        "\t}\r",
        "\telse {\r",
        "\t\tif (itc_depr_choice != 'none') {\r",
        "\t\t\tvalue(itc_depr_choice, value('itc_cost_basis_percent'));\r",
        "\t\t}\r",
        "\t\tif (non_itc_depr_choice != 'none') {\r",
        "\t\t\tvalue(non_itc_depr_choice, 100 - value('itc_cost_basis_percent'));\r",
        "\t\t}\r",
        "\t}\r",
        "\t\t\r",
        "\t\r",
        "}"
    ]
